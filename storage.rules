rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload story images
    match /stories/{userId}/{filename} {
      // Only authenticated users can upload
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024  // Max 5MB
                   && request.resource.contentType.matches('image/.*');  // Only images
      
      // Anyone authenticated can read stories
      allow read: if request.auth != null;
    }
    
    // Allow authenticated users to upload post media (images/videos)
    match /posts/{userId}/{filename} {
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024  // Max 10MB
                   && (request.resource.contentType.matches('image/.*') 
                       || request.resource.contentType.matches('video/.*'));
      allow read: if request.auth != null;
    }
    
    // Allow authenticated users to upload general media
    match /media/{userId}/{filename} {
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024;  // Max 10MB
      allow read: if request.auth != null;
    }
  }
}
